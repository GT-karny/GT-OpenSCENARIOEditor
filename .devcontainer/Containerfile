# Base image ships Node 20 LTS, Wine, and electron-builder native deps.
# Used to cross-build the Windows .exe from inside a Linux container.
FROM electronuserland/builder:wine

ARG USERNAME=vscode
ARG USER_UID=1000
ARG USER_GID=$USER_UID
ARG PNPM_VERSION=10.30.3

# Non-root user with passwordless sudo (VSCode dev container convention).
RUN groupadd --gid $USER_GID $USERNAME \
    && useradd --uid $USER_UID --gid $USER_GID -m $USERNAME -s /bin/bash \
    && apt-get update \
    && apt-get install -y --no-install-recommends sudo git ca-certificates \
    && rm -rf /var/lib/apt/lists/* \
    && echo "$USERNAME ALL=(root) NOPASSWD:ALL" > /etc/sudoers.d/$USERNAME \
    && chmod 0440 /etc/sudoers.d/$USERNAME

# Pin pnpm to match the host version via corepack.
RUN corepack enable \
    && corepack prepare pnpm@${PNPM_VERSION} --activate

# Pre-create pnpm dirs so the named volume mount inherits correct ownership.
RUN mkdir -p /home/$USERNAME/.local/share/pnpm/store \
    && chown -R $USERNAME:$USERNAME /home/$USERNAME/.local

USER $USERNAME
ENV SHELL=/bin/bash
ENV PNPM_HOME=/home/$USERNAME/.local/share/pnpm
ENV PATH=$PNPM_HOME:$PATH

# Wine writes its prefix here on first invocation; pre-create to avoid races.
RUN mkdir -p /home/$USERNAME/.wine
