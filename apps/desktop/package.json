{
  "name": "@osce/desktop",
  "version": "0.9.0-dev02",
  "private": true,
  "type": "module",
  "description": "OpenSCENARIO Editor desktop application",
  "author": "GT-karny",
  "main": "dist/main/index.mjs",
  "scripts": {
    "build": "node scripts/bundle.mjs",
    "build:check": "tsc --project tsconfig.main.json --noEmit",
    "dev": "node scripts/dev.mjs",
    "dist": "pnpm build && node scripts/dist.mjs",
    "dist:win": "pnpm build && npx electron-builder --config electron-builder.yml --win",
    "dist:mac": "pnpm build && npx electron-builder --config electron-builder.yml --mac",
    "dist:linux": "pnpm build && npx electron-builder --config electron-builder.yml --linux"
  },
  "dependencies": {
    "fastify": "^5.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/websocket": "^11.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/static": "^8.0.0",
    "@grpc/grpc-js": "^1.12.0",
    "@grpc/proto-loader": "^0.7.0",
    "adm-zip": "^0.5.16",
    "electron-store": "^10.0.0"
  },
  "devDependencies": {
    "@osce/server": "workspace:*",
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.7.0"
  }
}
